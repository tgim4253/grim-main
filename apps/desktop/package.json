{
  "name": "@grim/desktop",
  "version": "0.3.1",
  "private": true,
  "type": "module",
  "scripts": {
    "theme:build": "node scripts/build-theme.mjs",
    "dev:local-db": "node scripts/dev-local-db.mjs",
    "dev:db": "node ../../scripts/backend-export-dburl.mjs",
    "db:dev": "pnpm run dev:db",
    "dev:reset-db": "node scripts/reset-dev-db.mjs && pnpm run dev",
    "predev": "node scripts/build-theme.mjs",
    "dev": "tauri dev",
    "db:prepare": "node ../../scripts/backend-sqlx-prepare.mjs",
    "previte": "node scripts/build-theme.mjs",
    "vite": "vite",
    "demo:library": "node scripts/build-theme.mjs && vite --open /library-demo/",
    "prebuild": "node scripts/build-theme.mjs",
    "build": "tsc && pnpm run ipc:check && vite build",
    "ipc:check": "node scripts/check-ipc-contract.mjs",
    "prepreview": "node scripts/build-theme.mjs",
    "preview": "vite preview",
    "ui:demo": "node scripts/build-theme.mjs && vite --open /ui-demo/",
    "tauri": "tauri"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tauri-apps/api": "2.10.1",
    "@tauri-apps/plugin-dialog": "^2.3.2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "2.10.1",
    "@types/node": "^24.3.0",
    "i18next": "^25.3.2",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-http-backend": "^3.0.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^15.6.1",
    "react-router-dom": "^7.7.1",
    "zustand": "^5.0.7"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.5.6",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  }
}
