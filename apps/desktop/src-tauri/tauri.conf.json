{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "grim-app",
  "version": "0.1.0",
  "identifier": "grim-app",
  "build": {
    "beforeDevCommand": "pnpm --filter @grim/desktop vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm --filter @grim/desktop build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null,
      
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$DOCUMENT/**",
          "$HOME/**",

          "/Volumes/**",

          "$APPCACHE/**",

          "/media/**",
          "/run/media/**",

          "D:/**",
          "E:/**",
          "F:/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}

