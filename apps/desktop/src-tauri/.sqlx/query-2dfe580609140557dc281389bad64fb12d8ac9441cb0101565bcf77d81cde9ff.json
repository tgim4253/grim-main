  "query": "\n            SELECT t.id,\n                   t.group_id,\n                   t.name,\n                   t.color,\n                   t.sort_order,\n                   t.created_at,\n                   t.updated_at\n            FROM tag t\n            INNER JOIN croquis_record_tag crt ON crt.tag_id = t.id\n            WHERE crt.record_id = ?1\n            ORDER BY t.name ASC\n            ",
