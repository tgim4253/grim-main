  "db_name": "SQLite",
  "query": "\n            SELECT\n                fp.file_name,\n                fp.folder_id,\n                fp.file_name_norm,\n                fp.mtime,\n                fp.is_found,\n                fc.mime,\n                fc.size,\n                fc.xxh3_64,\n                fc.sha256,\n                fc.kind\n            FROM file_path fp\n            JOIN file_path_content_binding fpcb ON fp.id = fpcb.file_path_id\n            JOIN file_content fc ON fpcb.file_content_id = fc.id\n            WHERE fp.id = ?1 AND fpcb.is_active = 1\n            ",
