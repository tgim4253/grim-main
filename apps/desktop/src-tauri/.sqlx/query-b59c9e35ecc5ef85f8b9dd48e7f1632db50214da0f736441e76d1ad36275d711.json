  "query": "\n            SELECT id,\n                   title,\n                   source_asset_id,\n                   result_asset_id,\n                   target_duration_seconds,\n                   actual_duration_seconds,\n                   finished_at,\n                   created_at,\n                   updated_at\n            FROM croquis_record\n            WHERE (source_asset_id = ?1 OR result_asset_id = ?1)\n              AND finished_at IS NOT NULL\n            ORDER BY finished_at DESC, created_at DESC\n            LIMIT 24\n            ",
