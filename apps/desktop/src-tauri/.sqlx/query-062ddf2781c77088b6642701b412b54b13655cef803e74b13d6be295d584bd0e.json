  "query": "\n            SELECT t.id,\n                   t.group_id,\n                   t.name,\n                   t.color,\n                   t.sort_order,\n                   t.created_at,\n                   t.updated_at\n            FROM tag t\n            INNER JOIN asset_tag at ON at.tag_id = t.id\n            WHERE at.asset_id = ?1\n            ORDER BY t.name ASC\n            ",
